# ===================================================
# คัดลอกไฟล์นี้ไปเป็น .env แล้วใส่ key จริง
# cp .env.example .env
# ===================================================

# โหมด: true = Testnet (เงินปลอม), false = Live (เงินจริง)
BINANCE_TESTNET=true

# API Keys จาก Binance หรือ Testnet
BINANCE_API_KEY=ssxx
BINANCE_SECRET_KEY=xx

# การแจ้งเตือน (optional)
LINE_NOTIFY_TOKEN=your_line_token_here
