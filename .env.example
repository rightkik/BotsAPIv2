# ── Telegram ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Settrade (Phase 2 — realtime price feed) ───────────
# สมัครที่ developer.settrade.com → สร้าง App → ได้ app_id, app_secret, app_code
# broker_id = รหัสโบรกเกอร์ของคุณ (เช่น Finansia=001, KGI=008, ฯลฯ)
# ใช้ SANDBOX เพื่อทดสอบก่อน:  SETTRADE_BROKER_ID=SANDBOX
SETTRADE_APP_ID=your_app_id
SETTRADE_APP_SECRET=your_app_secret
SETTRADE_APP_CODE=your_app_code
SETTRADE_BROKER_ID=your_broker_code
